#!/bin/sh

case $1 in
count)
	gh api \
		-H "Accept: application/vnd.github+json" \
		-H "X-GitHub-Api-Version: 2022-11-28" \
		/repos/adeo/opus-knowledge-graph/pulls | jq length
	exit 1
	;;
*)
	list=$(gh api \
		-H "Accept: application/vnd.github+json" \
		-H "X-GitHub-Api-Version: 2022-11-28" \
		/repos/adeo/opus-knowledge-graph/pulls | jq -r '.[] | ((.number|tostring) + " " + .title)')
	selected=$(echo "$list" | rofi -dmenu -p "Run: " | cut -d ' ' -f1)
	if [ -z "$selected" ]; then
		exit 1
	fi
	url=$(gh api \
		-H "Accept: application/vnd.github+json" \
		-H "X-GitHub-Api-Version: 2022-11-28" \
		/repos/adeo/opus-knowledge-graph/pulls/$selected | jq -r '.html_url')
	$($BROWSER $url)

	exit 1
	;;
esac
