#!/bin/sh

export repo=adeo/opus-knowledge-graph
list=$(
	gh api -H "Accept: application/vnd.github+json" -H "X-GitHub-Api-Version: 2022-11-28" \
		/repos/$repo/pulls | jq -r '.[] | ((.number|tostring) + " " + .title)'
)
selected=$(echo "$list" | rofi -dmenu -p "Run: " | cut -d ' ' -f1)
if [ -z "$selected" ]; then
	exit 1
fi
url=$(
	gh api -H "Accept: application/vnd.github+json" -H "X-GitHub-Api-Version: 2022-11-28" \
		/repos/$repo/pulls/$selected | jq -r '.html_url'
)
$($BROWSER $url)
